@page "/clothing"
@using MutirithiaYou_MeBoutique.Models
@using MutirithiaYou_MeBoutique.Services
@inject InventoryService InventoryService

<PageTitle>Mutirithia Boutique | Clothing</PageTitle>

<div class="mb-4">
    <h1 class="h2 fw-bold text-dark">👗 Clothing Catalog</h1>
    <p class="text-muted">Explore our latest trends in premium attire. Prices negotiable.</p>
</div>

<div class="row g-4">
    @if (items == null)
    {
        <p>Loading apparel collections...</p>
    }
    else if (!items.Any())
    {
        <p>No clothing items currently in stock. Check back later!</p>
    }
    else
    {
        @foreach (var item in items)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm rounded-3 overflow-hidden">
                    <img src="@item.ImageUrl" class="card-img-top bg-light object-fit-cover" style="height: 240px;" alt="@item.Name">
                    <div class="card-body d-flex flex-column p-3">
                        <h5 class="card-title fw-bold text-dark">@item.Name</h5>
                        <p class="card-text text-muted small flex-grow-1">@item.Description</p>

                        <div class="bg-light p-2 rounded mb-3 small border border-light">
                            <strong>Sizes Available:</strong> @item.SizeRange <br />
                            <strong>Colors Available:</strong> @string.Join(", ", item.AvailableColors)
                        </div>

                        @{
                            string clothingPhone = "254711111111"; // 👗 Enter your clothing number
                            string customMessage = $"Hi Mutirithia! I am interested in negotiating for the clothing item: \"{item.Name}\"";
                            string whatsappUrl = $"https://wa.me{clothingPhone}?text={Uri.EscapeDataString(customMessage)}";
                        }

                        <a href="@whatsappUrl" target="_blank" class="btn btn-success d-flex align-items-center justify-content-center gap-2 py-2 fw-bold w-100 shadow-sm">
                            💬 Negotiate Clothing Price
                        </a>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<BoutiqueItem>? items;

    protected override async Task OnInitializedAsync()
    {
        // Automatically filter data so only clothing shows here
        items = await InventoryService.GetItemsByCategoryAsync(ItemCategory.Clothing);
    }
}

