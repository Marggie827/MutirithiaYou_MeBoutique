@page "/"
@using MutirithiaYou_MeBoutique.Models
@using MutirithiaYou_MeBoutique.Services
@inject InventoryService InventoryService

<PageTitle>Mutirithia Boutique | New Arrivals</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h2 fw-bold text-dark">What's New In Store ✨</h1>
        <p class="text-muted">Skipped the trip! View our freshly unpacked inventory instantly below.</p>
    </div>
</div>

<div class="row g-4">
    @if (items == null)
    {
        <div class="col-12 text-center">
            <p class="text-muted">Loading the latest arrivals...</p>
        </div>
    }
    else if (!items.Any())
    {
        <div class="col-12 text-center">
            <p class="text-muted">Check back soon! New arrivals refresh weekly.</p>
        </div>
    }
    else
    {
        @foreach (var item in items)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm rounded-3 overflow-hidden">
                    <img src="@item.ImageUrl" class="card-img-top bg-light object-fit-cover" style="height: 240px;" alt="@item.Name">
                    <div class="card-body d-flex flex-column p-3">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge bg-dark px-2 py-1">@item.Category.ToString()</span>
                            <span class="badge bg-danger text-white">NEW</span>
                        </div>
                        <h5 class="card-title fw-bold text-dark">@item.Name</h5>
                        <p class="card-text text-muted small flex-grow-1">@item.Description</p>

                        <div class="bg-light p-2 rounded mb-3 small border border-light">
                            <strong>Sizes:</strong> @item.SizeRange <br />
                            <strong>Colors:</strong> @string.Join(", ", item.AvailableColors)
                        </div>
                        @{
                            // 1. Ensure NO spaces, NO dashes, NO plus signs (+) inside these quotes
                            string clothingPhone = "254729907653"; // 👗 Enter your real digits here
                            string footwearPhone = "254720688992"; // 👟 Your real number seen in the image

                            // 2. Select the target phone number based on item category
                            string targetPhone = item.Category == ItemCategory.Clothing ? clothingPhone : footwearPhone;

                            // 3. NOTICE THE EXPLICIT SLASH (/) AFTER wa.me AND BEFORE the number variable
                            string customMessage = $"Hi Mutirithia! I saw the \"{item.Name}\" on your website. Is it available?";
                            string whatsappUrl = $"https://wa.me/{targetPhone}?text={Uri.EscapeDataString(customMessage)}";
                        }

                        <a href="@whatsappUrl" target="_blank" class="btn btn-success d-flex align-items-center justify-content-center gap-2 py-2 fw-bold w-100 shadow-sm">
                            💬 Negotiate Price on WhatsApp
                        </a>

                       
                            // 2. Automatically select the target number based on the item category
                            string targetPhone = item.Category == ItemCategory.Clothing ? clothingPhone : footwearPhone;

                            // 3. Build the tailored message and web link
                            string customMessage = $"Hi Mutirithia! I saw the \"{item.Name}\" on your website. Is it available? Let's negotiate the price.";
                            string whatsappUrl = $"https://wa.me{targetPhone}?text={Uri.EscapeDataString(customMessage)}";

                            }
                        <a href="@whatsappUrl" target="_blank" class="btn btn-success d-flex align-items-center justify-content-center gap-2 py-2 fw-bold w-100 shadow-sm">
                            💬 Negotiate Price on WhatsApp
                        </a>


                        <a href="@whatsappUrl" target="_blank" class="btn btn-success d-flex align-items-center justify-content-center gap-2 py-2 fw-bold w-100 shadow-sm">
                            💬 Negotiate Price on WhatsApp
                        </a>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<BoutiqueItem>? items;

    protected override async Task OnInitializedAsync()
    {
        items = await InventoryService.GetNewArrivalsAsync();
    }
}
