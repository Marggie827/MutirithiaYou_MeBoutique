@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar bg-dark text-white p-3">
        <h3 class="fw-bold text-center border-b pb-3 text-warning">Mutirithia</h3>
        <p class="text-center text-muted small">You & Me Boutique</p>
        <nav class="nav flex-column mt-4">
            <NavLink class="nav-link text-white py-2" href="" Match="NavLinkMatch.All">✨ New Arrivals</NavLink>
            <NavLink class="nav-link text-white py-2" href="clothing">👗 Clothing Catalog</NavLink>
            <NavLink class="nav-link text-white py-2" href="footwear">👟 Footwear Catalog</NavLink>
        </nav>
    </div>

    <main>
        <div class="top-row px-4 justify-content-between align-items-center border-bottom">
            <span class="text-secondary fw-semibold">Dashboard / Client Digital Showcase</span>
            <span class="badge bg-success p-2">🏷️ Prices Negotiable via WhatsApp/Call</span>
        </div>

        <article class="content px-4 py-4">
            @Body
        </article>
    </main>
</div>
